{
    "name": "fabpot/amphp-sqlite",
    "description": "Asynchronous SQLite client for PHP based on Amp.",
    "keywords": [
        "database",
        "db",
        "sqlite",
        "asynchronous",
        "async"
    ],
    "homepage": "https://github.com/fabpot/amp-sqlite3",
    "license": "MIT",
    "authors": [
        {
            "name": "Fabien Potencier",
            "email": "fabien@potencier.org"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-sqlite3": "*",
        "amphp/amp": "^3",
        "amphp/byte-stream": "^2",
        "amphp/parallel": "^2",
        "amphp/sql": "^2",
        "amphp/sql-common": "^2"
    },
    "require-dev": {
        "amphp/php-cs-fixer-config": "^2",
        "phpunit/phpunit": "^13.2",
        "psalm/phar": "6.16.1"
    },
    "autoload": {
        "psr-4": {
            "Fabpot\\Amp\\Sqlite\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fabpot\\Amp\\Sqlite\\Test\\": "test"
        }
    },
    "scripts": {
        "check": [
            "@cs",
            "@psalm",
            "@test"
        ],
        "cs": "php-cs-fixer fix --show-progress=none --diff --dry-run",
        "cs-fix": "php-cs-fixer fix --show-progress=none --diff",
        "psalm": "@php ./vendor/bin/psalm.phar --no-cache",
        "test": "@php -dzend.assertions=1 -dassert.exception=1 ./vendor/bin/phpunit"
    }
}
